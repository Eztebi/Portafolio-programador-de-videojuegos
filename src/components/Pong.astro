<!--Juego-->
<section id="juego">
    <h2>Jueguito</h2>
    <div id="player"></div>
    <div id="ball"></div>

    <style>
        #juego {
            position: relative;
            width: 100%;
            height: 400px;
            background-color: black;
            overflow: hidden;
            margin-top: 1rem;
            border-radius: 10px;
        }
        #player {
            width: 50px;
            height: 50px;
            background-color: red;
            border-radius: 50%;
            position: absolute;
            top: 50%;
            left: 50px;
            transform: translateY(-50%);
        }
        #ball {
            width: 20px;
            height: 20px;
            background: yellow;
            border-radius: 50%;
            position: absolute;
            top: 50%;
            left: 200px;
            transform: translate(-50%, -50%);
        }
    </style>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const player = document.getElementById("player");
            const ball = document.getElementById("ball");
            const juego = document.getElementById("juego");

            if (!player || !ball || !juego) return;

            let playerY = 175;
            let playerX = 175;
            let ballX = 200;
            let ballY = 200;
            let ballAccX = 0;
            let ballAccY = 0;
            let ballVelX = 0;
            let ballVelY = 0;
            const ballMaxSpeed = 5;
            let lastPlayerX = playerX;
            let lastPlayerY = playerY;
            const playerForce = 2;
            let canHit = true;
            const friction = 0.99;
            juego.addEventListener("mousemove", (e) => {
                const rect = juego.getBoundingClientRect();
                let mouseY = e.clientY - rect.top;
                let mouseX = e.clientX - rect.left;
                mouseY = Math.max(
                    50,
                    Math.min(mouseY - 10, juego.clientHeight - 50),
                );
                mouseX = Math.max(
                    0,
                    Math.min(mouseX - 30, juego.clientWidth - 50),
                );
                playerY = mouseY;
                playerX = mouseX;
                player.style.top = playerY + "px";
                player.style.left = playerX + "px";
            });

            function gameLoop() {
                if (ballX <= 0) {
                    ballX = 0;
                    ballVelX *= -1;
                }
                if (ballX >= juego.clientWidth - 20) {
                    ballX = juego.clientWidth - 20;
                    ballVelX *= -1;
                }
                if (ballY <= 0) {
                    ballY = 0;
                    ballVelY *= -1;
                }
                if (ballY >= juego.clientHeight - 20) {
                    ballY = juego.clientHeight - 20;
                    ballVelY *= -1;
                }

                const playerVelX = playerX - lastPlayerX;
                const playerVelY = playerY - lastPlayerY;
                lastPlayerX = playerX;
                lastPlayerY = playerY;

                ballVelX += ballAccX;
                ballVelY += ballAccY;

                const speed = Math.sqrt(ballVelX ** 2 + ballVelY ** 2);
                if (speed > ballMaxSpeed) {
                    ballVelX = (ballVelX / speed) * ballMaxSpeed;
                    ballVelY = (ballVelY / speed) * ballMaxSpeed;
                }

                ballVelX *= friction;
                ballVelY *= friction;

                ballX += ballVelX;
                ballY += ballVelY;

                ballAccX = 0;
                ballAccY = 0;

                if (
                    ballX + 20 > playerX &&
                    ballX < playerX + 50 &&
                    ballY + 20 > playerY &&
                    ballY < playerY + 50
                ) {
                    let dirX = ballX + 10 - (playerX + 25);
                    let dirY = ballY + 10 - (playerY + 25);

                    const length = Math.sqrt(dirX * dirX + dirY * dirY) || 1;
                    dirX /= length;
                    dirY /= length;

                    ballVelX = dirX * ballMaxSpeed + playerVelX * 0.2;
                    ballVelY = dirY * ballMaxSpeed + playerVelY * 0.2;

                    ballX += dirX * 5;
                    ballY += dirY * 5;
                }
                ball.style.left = ballX + "px";
                ball.style.top = ballY + "px";

                requestAnimationFrame(gameLoop);
            }

            gameLoop();
        });
    </script>
</section>
