<!--Juego-->
<section id="juego">
    <h2>Jueguito</h2>
    <div id="player"></div>
    <div id="ball"></div>

    <style>
        #juego {
            position: relative;
            width: 100%;
            height: 600px;
            background-color: black;
            overflow: hidden;
            margin-top: 1rem;
            border-radius: 10px;
        }
        #player {
            width: 50px;
            height: 50px;
            background-color: red;
            border-radius: 50%;
            position: absolute;
            top: 50%;
            left: 50px;
            transform: translateY(-50%);
        }
        #ball {
            width: 20px;
            height: 20px;
            background: yellow;
            border-radius: 50%;
            position: absolute;
            top: 50%;
            left: 200px;
            transform: translate(-50%, -50%);
        }
    </style>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const player = document.getElementById("player");
            const ball = document.getElementById("ball");
            const juego = document.getElementById("juego");

            if (!player || !ball || !juego) return;

            let playerY = 175;
            let playerX = 175;
            let ballX = juego.clientHeight / 2;
            let ballY = juego.clientWidth / 2;
            let ballAccX = 0;
            let ballAccY = 0;
            let ballVelX = 0;
            let ballVelY = 0;
            const ballMaxSpeed = 15;
            let lastPlayerX = playerX;
            let lastPlayerY = playerY;
            let playerForce = 0.5;
            let canHit = true;
            const friction = 0.99;
            const playerRadius = 25;
            const ballRadius = 10;
            let lastTime=0;
            juego.addEventListener("mousemove", (e) => {
                const rect = juego.getBoundingClientRect();
                let mouseY = e.clientY - rect.top;
                let mouseX = e.clientX - rect.left;
                mouseY = Math.max(
                    25,
                    Math.min(mouseY +5, juego.clientHeight -25),
                );
                mouseX = Math.max(
                    0,
                    Math.min(mouseX - 25, juego.clientWidth - 50),
                );
                playerY = mouseY;
                playerX = mouseX;
                player.style.top = playerY + "px";
                player.style.left = playerX + "px";
            });

function gameLoop(timestamp) {
        const dt = lastTime ? (timestamp - lastTime) / 16.6 : 1;
    lastTime = timestamp;

        if (ballX <= 0) {
            ballX = 0;
            ballVelX *= -1;
        }
        if (ballX >= juego.clientWidth - 20) {
            ballX = juego.clientWidth - 20;
            ballVelX *= -1;
        }
        if (ballY <= 0) { // Corregido a 0 para que no rebote antes de tiempo
            ballY = 0;
            ballVelY *= -1;
        }
        if (ballY >= juego.clientHeight - 20) {
            ballY = juego.clientHeight - 20;
            ballVelY *= -1;
        }

        // Calcular velocidad del jugador en este frame
        const pVelX = playerX - lastPlayerX;
        const pVelY = playerY - lastPlayerY;

        ballVelX += ballAccX;
        ballVelY += ballAccY;

        const speed = Math.sqrt(ballVelX ** 2 + ballVelY ** 2);
        if (speed > ballMaxSpeed) {
            ballVelX = (ballVelX / speed) * ballMaxSpeed;
            ballVelY = (ballVelY / speed) * ballMaxSpeed;
        }

        ballVelX *= friction;
        ballVelY *= friction;
        ballX += ballVelX * dt;
        ballY += ballVelY * dt;

        ballAccX = 0;
        ballAccY = 0;

        if (
            ballX + 20 > playerX &&
            ballX < playerX + 50 &&
            ballY + 20 > playerY &&
            ballY < playerY + 50
        ) {
            const playerCenterX = playerX + playerRadius;
            const playerCenterY = playerY + playerRadius;
            const ballCenterX = ballX + ballRadius;
            const ballCenterY = ballY + ballRadius;

            const distX = ballCenterX - playerCenterX;
            const distY = ballCenterY - playerCenterY;
            const distLength = Math.hypot(distX, distY);
            const minDist = ballRadius + playerRadius;

            if (distLength < minDist) {
                const nX = distX / distLength;
                const nY = distY / distLength;

                const overlap = minDist - distLength;
                ballX += nX * overlap;
                ballY += nY * overlap;

                const pSpeed = Math.hypot(pVelX, pVelY);
                if (pSpeed > 0.5) {
                    ballAccX = nX * pSpeed * playerForce;
                    ballAccY = nY * pSpeed * playerForce;
                } else {
                    ballVelX = nX * (Math.abs(ballVelX) +1);
                    ballVelY = nY * (Math.abs(ballVelY) + 1);
                }
            }
        }
                lastPlayerX = playerX;
                lastPlayerY = playerY;
                ball.style.left = ballX + "px";
                ball.style.top = ballY + "px";

                requestAnimationFrame(gameLoop);
            }

            requestAnimationFrame(gameLoop);
        });
    </script>
</section>
