---
import AboutMe from "../components/AboutMe.astro";
import GameProject from "../components/GameProject.jsx";
import FooterContact from "../components/FooterContact.astro";
import NavBar from "../components/NavBar.astro";
import Layout from "../layouts/Layout.astro";
const name = "Esteban Hernández Valenzuela";
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>{name} | Portafolio</title>
    <style>html {scroll-behavior: smooth;}
    </style>
  </head>
  <body style="font-family: sans-serif; padding:2rem;">
    
    <!--Layout -->
    <Layout/>

    <!-- ABOUT -->
    <section id="about">
      <AboutMe />
      <p>
        Aquí puedes ver algunos de mis proyectos en los que he trabajado :)
      </p>
    </section>

    <!-- PROJECTS -->
    <section id="projects">
      <h2>Proyectos</h2>

      <GameProject
        title="Dino Hunter"
        description="Juego tipo Top Down Shooter. Este proyecto esta enfocado a GameFeel, para que el juego se sienta bien con el jugador y haya buenos efectos"
        tool="Unreal Engine · blueprints · los assets no son de mi propiedad"
        youtubeId="eQXG75XirdE"
        githubLink="https://github.com/Eztebi/Portafolio-programador-de-videojuegos"
      />
      <GameProject
        title="Proyecto de OpenGL"
        description="Proyectos Visuales en donde experimento con Iluminación por vertice y por texel, Height Map, Texturas y Coordenadas de Texturas"
        tool="OpenGL· C++ · assets"
        youtubeId="eQXG75XirdE"
        githubLink="https://github.com/Eztebi/Portafolio-programador-de-videojuegos"
      />
      <GameProject
        title="Candy Clicker"
        description="Juego tipo cookie clicker con guardado y autentificacion en base de datos FireBase."
        tool="Unity · C# · los assets no son de mi propiedad"
        youtubeId="eQXG75XirdE"
        githubLink="https://github.com/Eztebi/Portafolio-programador-de-videojuegos"
      />
      <GameProject
        title="GolF - Pea - Shooter o GolFPS"
        description="Juego de VR de golf y disparos. Este proyecto fue más enfocado a patrones de diseño como MVP, Observer, Factory y Combo pattern."
        tool="Unity · C# · los assets no son de mi propiedad"
        youtubeId="eQXG75XirdE"
        githubLink="https://github.com/Eztebi/Portafolio-programador-de-videojuegos"
      />
      <GameProject
        title="Another Day in Mars"
        description="Juego tipo Tower Defense, el cual esta enfocado a algoritmos de pathfinding como A*. "
        tool="Unity · C# · los assets no son de mi propiedad"
        youtubeId="eQXG75XirdE"
        githubLink="https://github.com/Eztebi/Portafolio-programador-de-videojuegos"
      />
    </section>

    <!-- CONTACT -->
    <section id="contact">
      <FooterContact />
    </section>
  </body>
</html>